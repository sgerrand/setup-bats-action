node_modules/

# Intermediate TypeScript compilation output (dist/ is committed, lib/ is not)
lib/

# Test runner temp files
__tests__/runner/*

# Coverage directory
coverage
*.lcov
.nyc_output

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# dotenv environment variables file
.env
.env.test

# OS metadata
.DS_Store
Thumbs.db
