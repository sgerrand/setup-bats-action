{
  "name": "setup-bats-action",
  "version": "1.0.1",
  "private": true,
  "description": "GitHub Action to install BATS (Bash Automated Testing System)",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js --legal-comments=external",
    "format": "prettier --config ./.prettierrc.js --write \"**/*.{md,ts,yml,yaml}\"",
    "format-check": "prettier --config ./.prettierrc.js --check \"**/*.{md,ts,yml,yaml}\"",
    "lint": "eslint \"**/*.ts\"",
    "lint:fix": "eslint \"**/*.ts\" --fix",
    "test": "bun test --coverage",
    "all": "bun run format && bun run lint:fix && bun run build && bun run test",
    "prepare": "lefthook install"
  },
  "keywords": [
    "actions",
    "bats",
    "bash",
    "testing",
    "setup"
  ],
  "author": "Sasha Gerrand",
  "license": "BSD-2-Clause",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/http-client": "^4.0.0",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "bun-types": "^1.3.12",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "lefthook": "^2.1.5",
    "prettier": "^3.6.2",
    "typescript": "^6.0.2"
  }
}
