{
  "name": "setup-bats-action",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action to install BATS (Bash Automated Testing System)",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "ncc build src/main.ts -o dist --license licenses.txt",
    "format": "prettier --config ./.prettierrc.js --write \"**/*.{md,ts,yml,yaml}\"",
    "format-check": "prettier --config ./.prettierrc.js --check \"**/*.{md,ts,yml,yaml}\"",
    "lint": "eslint \"**/*.ts\"",
    "lint:fix": "eslint \"**/*.ts\" --fix",
    "test": "jest --runInBand --coverage",
    "all": "bun run format && bun run lint:fix && bun run build && bun run test"
  },
  "keywords": [
    "actions",
    "bats",
    "bash",
    "testing",
    "setup"
  ],
  "author": "Sasha Gerrand",
  "license": "BSD-2-Clause",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/http-client": "^4.0.0",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-n": "^17.24.0",
    "jest": "^30.3.0",
    "jest-circus": "^30.3.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.3.2",
    "typescript": "^6.0.2"
  }
}
